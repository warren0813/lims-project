# Backend (Django)
# Generate with:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,testserver
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Local SQLite works when DATABASE_URL is omitted.
# Docker Compose uses PostgreSQL:
# DATABASE_URL=postgres://lims:lims@postgres:5432/lims

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=False

# Total simulated experiment runtime, in seconds, used by every Celery equipment worker.
# Restart backend + workers after changing this.
EXPERIMENT_DURATION_SECONDS=30
EQUIPMENT_SIMULATION_STEP_SECONDS=0.25

# JWT_SIGNING_KEY=your-jwt-signing-key-here
# JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
# JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Frontend (Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_REALTIME_URL=http://localhost:8000/api/realtime
